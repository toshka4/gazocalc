# ============================================================
# Калькулятор газобетона — Production Environment
# Скопируйте в .env.production и заполните значения
# ============================================================

# ── PostgreSQL ──
POSTGRES_USER=gazoblock
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=gazoblock

# ── Backend ──
PORT=3000
NODE_ENV=production
APP_BASE_URL=https://gazocalc.ru

# CORS: разрешённые домены
CORS_ORIGIN=https://gazocalc.ru,https://admin.gazocalc.ru

# Admin API Key (для admin-панели; сгенерируйте: openssl rand -hex 32)
ADMIN_API_KEY=

# ── Telegram Bot (опционально) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── SMTP (опционально) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gazocalc.ru
MANAGER_EMAIL=

# ── Rate Limiting ──
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
