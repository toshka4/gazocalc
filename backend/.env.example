# Server
PORT=3000
NODE_ENV=development
APP_BASE_URL=https://gazocalc.ru

# CORS: список доменов через запятую (в production обязательно)
CORS_ORIGIN=https://gazocalc.ru,https://admin.gazocalc.ru

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/gazoblock?schema=public

# Admin API Key (для защиты admin-эндпоинтов: GET/PATCH /api/leads, POST /api/pdf)
ADMIN_API_KEY=

# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@gazocalc.ru
MANAGER_EMAIL=manager@gazocalc.ru

# Rate Limiting (POST /api/leads)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000
